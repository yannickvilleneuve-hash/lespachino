# ============================================================
# Supabase
# ============================================================
# Project URL + clés — dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
# Clé publique anon (exposée au client, format JWT legacy eyJ...)
# Les nouveaux `sb_publishable_*` ne marchent pas avec @supabase/ssr 0.10.x.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role: JAMAIS exposé côté client — uniquement pour server actions
# + scripts admin (generateLink magic link, seed, bypass RLS).
SUPABASE_SERVICE_ROLE_KEY=

# URL publique du site (utilisé par sitemap.xml + OG).
# En prod: https://camion-hino.ca
NEXT_PUBLIC_SITE_URL=https://camion-hino.ca

# ============================================================
# SERTI DB2 (iSeries / AS400)
# ============================================================
# Mêmes noms que calendrier-service — NE PAS renommer. Pooled via node-jt400.
SERTI_DB2_HOST=
SERTI_DB2_USER=
SERTI_DB2_PASS=

# ============================================================
# Microsoft Graph API (Azure AD)
# ============================================================
# Envoi email depuis service@camion-hino.ca — OAuth2 client_credentials.
# Même config que calendrier-service. Sert pour magic links (auth) et leads
# (notif vendeurs).
GRAPH_TENANT=
GRAPH_CLIENT=
GRAPH_SECRET=
GRAPH_FROM=service@camion-hino.ca

# ============================================================
# Feeds tiers — optionnels, activés à l'arrivée des specs/clés
# ============================================================
# Kijiji Dealer Central — URL cible où Kijiji pulle notre feed XML.
# Obtenu via dashboard Kijiji → Feed Integration.
KIJIJI_FEED_URL=
KIJIJI_DEALER_ID=
KIJIJI_API_KEY=

# Lespac — REST JSON API. Clé générée dans ton compte Lespac:
# Profil → Plan mensuel → API → Générer identifiant.
LESPAC_API_TOKEN=
# Prod par défaut. Pour tester: https://ws.lespacstaging.com
LESPAC_API_BASE=https://ws.lespac.com

# Identité du concessionnaire affichée sur les annonces Lespac + leads.
DEALER_POSTAL_CODE=
DEALER_CONTACT_EMAIL=
DEALER_CONTACT_FIRST_NAME=
DEALER_CONTACT_LAST_NAME=
DEALER_CONTACT_PHONE=

# TRADER AutoSync — si on passe par leur syndication centralisée (couvre
# AutoTrader.ca + Lespac + Kijiji).
TRADER_AUTOSYNC_API_KEY=
TRADER_DEALER_ID=

# Facebook Marketplace Catalog — URL hébergée du CSV (rendu par
# /feed/facebook.csv). Colle-la dans Commerce Manager → Catalog → Data Feed.
# Pas de clé API côté Meta pour le catalogue — c'est un pull de ton côté.

# Wix Headless API — push nos véhicules dans la Wix Collection "Inventaire"
# pour que le site camion-hino.ca les affiche en composants natifs.
# Token: Wix Admin → Settings → Dev & APIs → Generate API Key.
WIX_API_TOKEN=
WIX_SITE_ID=
WIX_INVENTORY_COLLECTION_ID=Inventaire
