# Supabase (projet créé manuellement au dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role: JAMAIS exposé côté client — uniquement pour server actions /
# scripts d'admin (generateLink magic link, seed, RLS bypass).
SUPABASE_SERVICE_ROLE_KEY=

# SERTI DB2 (mêmes noms que calendrier-service — NE PAS renommer)
SERTI_DB2_HOST=
SERTI_DB2_USER=
SERTI_DB2_PASS=

# Microsoft Graph API (envoi email depuis service@camion-hino.ca)
# Réutilise la même config que calendrier-service.
GRAPH_TENANT=
GRAPH_CLIENT=
GRAPH_SECRET=
GRAPH_FROM=service@camion-hino.ca
